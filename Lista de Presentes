<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Presentes - Brenda & Talis</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent-pink: #f9a8d4;
            --dark-pink: #f472b6;
            --bg-soft: #fffafb;
        }

        body { 
            font-family: 'Montserrat', sans-serif; 
            background-color: var(--bg-soft); 
            color: #374151;
            scroll-behavior: smooth;
        }

        .font-romance { font-family: 'Great Vibes', cursive; }

        .card-gift {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .card-gift:hover { 
            transform: translateY(-5px); 
            box-shadow: 0 10px 15px -3px rgba(244, 114, 182, 0.1);
        }

        .modal-overlay { 
            display: none; 
            position: fixed; 
            inset: 0;
            background: rgba(0,0,0,0.5); 
            backdrop-filter: blur(4px);
            z-index: 50; 
            align-items: center; 
            justify-content: center;
            padding: 1rem;
        }

        .img-container { 
            aspect-ratio: 1 / 1; 
            position: relative;
            overflow: hidden;
            background-color: #fce7f3;
        }

        .img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .btn-gradient {
            background: linear-gradient(135deg, #f9a8d4 0%, #f472b6 100%);
        }
    </style>
</head>
<body class="antialiased">

    <header class="bg-white border-b border-pink-50 py-12 md:py-20 text-center relative overflow-hidden">
        <div class="relative z-10 px-4">
            <h1 class="text-5xl md:text-8xl font-romance text-pink-400 mb-4">Brenda & Talis</h1>
            <div class="flex items-center justify-center space-x-3 mb-6">
                <span class="h-px w-8 bg-pink-200"></span>
                <p class="text-gray-400 uppercase tracking-[0.2em] text-[10px] md:text-xs font-bold">Lista de Presentes • 2026</p>
                <span class="h-px w-8 bg-pink-200"></span>
            </div>
            <div class="max-w-xl mx-auto px-4">
                <p class="text-gray-500 italic text-sm md:text-base font-light">
                    "Sua presença é o nosso maior presente. Tudo será convertido em nossa nova vida!"
                </p>
            </div>
        </div>
    </header>

    <section class="sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-pink-50 py-4 mb-8">
        <div class="max-w-4xl mx-auto px-4">
            <div class="relative">
                <input type="text" id="searchInput" placeholder="Procurar um presente..." 
                    class="w-full bg-gray-50 border border-gray-100 rounded-full px-10 py-3 focus:outline-none focus:ring-2 focus:ring-pink-200 text-sm">
                <svg class="w-4 h-4 text-gray-400 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        </div>
    </section>

    <main class="max-w-7xl mx-auto px-4 pb-20">
        <div id="giftsGrid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-8">
            </div>
        <div id="noResults" class="hidden text-center py-20 text-gray-400 italic">
            Nenhum presente encontrado...
        </div>
    </main>

    <div id="pixModal" class="modal-overlay" onclick="closeModalOnOut(event)">
        <div class="bg-white rounded-[2rem] max-w-sm w-full p-6 md:p-8 relative shadow-2xl border border-pink-50">
            <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-300 hover:text-pink-400 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>

            <div class="text-center">
                <div class="w-16 h-16 bg-pink-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="h-8 w-8 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12z" />
                    </svg>
                </div>
                
                <h3 class="text-lg font-bold text-gray-800 mb-1" id="modalGiftTitle">Presentear</h3>
                <p class="text-pink-500 font-bold text-xl mb-6" id="modalGiftPrice"></p>
                
                <div class="space-y-3">
                    <button id="payBtn" class="w-full btn-gradient text-white font-bold py-4 rounded-xl shadow-lg active:scale-95 transition-transform">
                        Pagar Agora
                    </button>
                    
                    <button onclick="copyPix()" class="w-full bg-gray-50 text-gray-500 font-semibold py-3 rounded-xl border border-gray-100 flex items-center justify-center gap-2 text-sm">
                        Copiar Link
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="copyToast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-gray-800 text-white px-6 py-3 rounded-full text-sm opacity-0 transition-opacity pointer-events-none z-[60]">
        Link copiado!
    </div>

    <footer class="bg-white border-t border-pink-50 py-12 text-center text-gray-400 text-sm">
        <p class="mb-2 font-romance text-3xl text-pink-300">Brenda & Talis</p>
        <p>&copy; 2026 • Feito com amor</p>
    </footer>

    <script>
        const giftsData = [
            { id: 1, name: "Pix solidário", price: 40.00, img: "https://iili.io/B4PLYlI.jpg", pix: "https://mpago.li/1My5mHd" },
            { id: 2, name: "Controle extra para não ter briga", price: 55.00, img: "https://iili.io/B4PL7KN.jpg", pix: "https://mpago.li/1E8UXkL" },
            { id: 3, name: "Ajudinha no dia da noiva", price: 61.00, img: "https://iili.io/B4PLaSt.jpg", pix: "https://mpago.li/1bcHEPP" },
            { id: 4, name: "Primeiro lugar na fila do buffet", price: 57.00, img: "https://iili.io/B4PLRPp.jpg", pix: "https://mpago.li/2PgHriM" },
            { id: 5, name: "Patrocínio cinema", price: 49.00, img: "https://iili.io/B4PLAVR.jpg", pix: "https://mpago.li/2sXQMqm" },
            { id: 6, name: "Mensalidade da academia do noivo", price: 80.00, img: "https://iili.io/B4PLuov.jpg", pix: "https://mpago.li/2YZb9ik" },
            { id: 7, name: "Lenço para a noiva não borrar a make", price: 70.00, img: "https://iili.io/B4PmqKv.jpg", pix: "https://mpago.li/2ppyEre" },
            { id: 8, name: "Calmante para o dia do casamento", price: 85.00, img: "https://iili.io/B4PLIDJ.jpg", pix: "https://mpago.li/2FVrHBG" },
            { id: 9, name: "Terapia dos noivos", price: 100.00, img: "https://iili.io/B4PLzNa.jpg", pix: "https://mpago.li/2XPMYZJ" },
            { id: 10, name: "Trocar a bateria da bike do casal", price: 160.00, img: "https://iili.io/B4PLxAg.jpg", pix: "https://mpago.li/2aTbUdF" },
            { id: 11, name: "Rolo de macarrão para quando a noiva se estressar", price: 110.00, img: "https://iili.io/B4PLCS1.jpg", pix: "https://mpago.li/2kA5Tzt" },
            { id: 12, name: "Capacete contra rolo de macarrão", price: 120.00, img: "https://iili.io/B4PLoHF.jpg", pix: "https://mpago.li/2Eg7uQQ" },
            { id: 13, name: "Jogar o buquê na sua direção", price: 115.00, img: "https://iili.io/B4PLBcP.jpg", pix: "https://mpago.li/2tSBAoi" },
            { id: 14, name: "Cobertor para a noiva sempre estar coberta de razão", price: 75.00, img: "https://iili.io/B4PLKPV.jpg", pix: "https://mpago.li/2BqU1Eb" },
            { id: 15, name: "Dose de paciência para a noiva", price: 150.00, img: "https://iili.io/B4PLHAu.jpg", pix: "https://mpago.li/2xKJD2J" },
            { id: 16, name: "Jogo de panelas moderno", price: 180.00, img: "https://iili.io/B4PLdtj.jpg", pix: "https://mpago.li/2xEAytN" },
            { id: 17, name: "Ajuda para pagar os cílios da noiva", price: 170.00, img: "https://iili.io/B4PL3ox.jpg", pix: "https://mpago.li/1vZ2JbJ" },
            { id: 18, name: "Deus te iluminou e você quis pagar o casamento no civil", price: 736.00, img: "https://iili.io/B4PLFMQ.jpg", pix: "https://mpago.li/1EFz2M5" },
        ];

        const sortedGifts = [...giftsData].sort((a, b) => a.price - b.price);
        const grid = document.getElementById('giftsGrid');
        const searchInput = document.getElementById('searchInput');
        const modal = document.getElementById('pixModal');
        const modalTitle = document.getElementById('modalGiftTitle');
        const modalPrice = document.getElementById('modalGiftPrice');
        const toast = document.getElementById('copyToast');
        let currentActiveLink = "";

        function renderGifts(filter = "") {
            grid.innerHTML = "";
            const filtered = sortedGifts.filter(g => g.name.toLowerCase().includes(filter.toLowerCase()));
            
            if (filtered.length === 0) {
                document.getElementById('noResults').classList.remove('hidden');
            } else {
                document.getElementById('noResults').classList.add('hidden');
                filtered.forEach(gift => {
                    const card = document.createElement('div');
                    card.className = "card-gift bg-white rounded-2xl shadow-sm border border-pink-50 overflow-hidden flex flex-col";
                    card.innerHTML = `
                        <div class="img-container">
                            <img src="${gift.img}" alt="${gift.name}" loading="lazy" onerror="this.src='https://placehold.co/400x400/fce7f3/f472b6?text=Presente'">
                        </div>
                        <div class="p-3 md:p-6 flex flex-col flex-grow text-center">
                            <h2 class="text-[10px] md:text-xs font-bold text-gray-400 mb-1 uppercase tracking-tight line-clamp-2 min-h-[30px]">${gift.name}</h2>
                            <p class="text-gray-800 font-extrabold text-sm md:text-xl mb-3">R$ ${gift.price.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</p>
                            <button onclick="openModal('${gift.name}', '${gift.pix}', '${gift.price}')" class="mt-auto w-full bg-pink-50 text-pink-500 font-bold py-2 md:py-3 rounded-lg text-[9px] md:text-[11px] uppercase tracking-wider hover:bg-pink-400 hover:text-white transition-colors">
                                Escolher
                            </button>
                        </div>
                    `;
                    grid.appendChild(card);
                });
            }
        }

        function openModal(title, link, price) {
            modalTitle.innerText = title;
            modalPrice.innerText = `R$ ${parseFloat(price).toLocaleString('pt-BR', { minimumFractionDigits: 2 })}`;
            currentActiveLink = link;
            modal.style.display = "flex";
            document.body.style.overflow = "hidden";
        }

        function closeModal() {
            modal.style.display = "none";
            document.body.style.overflow = "auto";
        }

        function closeModalOnOut(e) {
            if (e.target === modal) closeModal();
        }

        function copyPix() {
            const el = document.createElement('textarea');
            el.value = currentActiveLink;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
            toast.style.opacity = "1";
            setTimeout(() => toast.style.opacity = "0", 2500);
        }

        // Event Listener robusto para o redirecionamento
        document.getElementById('payBtn').addEventListener('click', function() {
            if (currentActiveLink) {
                window.location.href = currentActiveLink;
            }
        });

        searchInput.addEventListener('input', (e) => renderGifts(e.target.value));
        renderGifts();
    </script>
</body>
</html>
